@model Maritimo.Models.Models.Barco

@{
    ViewData["Title"] = "Create";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
        <button class="btn btn-sm btn-outline-dark"
                onclick="this.closest('.alert').remove()">
            ✖
        </button>
    </div>
}

<h1>Create</h1>

<h4>Barco</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Matricula" class="control-label"></label>
                <input asp-for="Matricula" class="form-control" />
                <span asp-validation-for="Matricula" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Tonelaje" class="control-label"></label>
                <input asp-for="Tonelaje" class="form-control" />
                <span asp-validation-for="Tonelaje" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">

                @Html.LabelFor(m => m.PuertoId, "Puertos")

                @Html.DropDownListFor(
                    m => m.PuertoId,
                    (IEnumerable<SelectListItem>)ViewBag.Puertos,
                    "Seleccione un Puerto",
                    new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.PuertoId, "", new { @class = "text-danger" })
            </div>
            <div class="form-group">
                <label asp-for="ModeloMotor" class="control-label"></label>
                <input asp-for="ModeloMotor" class="form-control" />
                <span asp-validation-for="ModeloMotor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PotenciaMotor" class="control-label"></label>
                <input asp-for="PotenciaMotor" class="form-control" />
                <span asp-validation-for="PotenciaMotor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HoraUsoMotor" class="control-label"></label>
                <input asp-for="HoraUsoMotor" class="form-control" />
                <span asp-validation-for="HoraUsoMotor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}





