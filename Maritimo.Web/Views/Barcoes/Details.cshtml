@model Maritimo.Models.Models.Barco

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Barco</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Matricula)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Matricula)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tonelaje)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tonelaje)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PuertoId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PuertoId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ModeloMotor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ModeloMotor)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PotenciaMotor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PotenciaMotor)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.HoraUsoMotor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.HoraUsoMotor)
        </dd>
    </dl>
</div>

<br/>

<div>
    <h4> Rutas Actuales del Barco @Model.Nombre</h4>
    <hr />
    <dl class="row">
        @if (@ViewBag.RutasActual != null)
        {
            <table class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>
                            Ruta
                        </th>
                        <th>
                            Fechas Salida
                        </th>
                        <th>
                            Fechas Llegada
                        </th>
                        <th>
                            Estado
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in @ViewBag.RutasActual)
                    {
                        <tr>
                            <td>
                                @item.puertoSalidaId + " - " + @item.puertoSalidaId
                            </td>
                            <td>
                                @item.FechaPrevistaSalida
                            </td>
                            <td>
                                @item.FechaPrevistaLlegada
                            </td>
                            <td>
                                @item.Estado
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <h4>Este Barco no tiene rutas actuales</h4>
        }
    </dl>
</div>

<br />

<div>
    <h4> Rutas Actuales del Barco @Model.Nombre</h4>
    <hr />
    <dl class="row">
        @if (@ViewBag.RutasHistorial != null)
        {
            <table class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>
                            Ruta
                        </th>
                        <th>
                            Fechas Salida
                        </th>
                        <th>
                            Fechas Llegada
                        </th>
                        <th>
                            Estado
                        </th>
                    </tr>
                </thead>
        


                <tbody>
                    @foreach (var item in @ViewBag.RutasHistorial)
                    {
                        <tr>
                            <td>
                                @item.puertoSalidaId + " - " + @item.puertoSalidaId
                            </td>
                            <td>
                                @item.FechaPrevistaSalida
                            </td>
                            <td>
                                @item.FechaPrevistaLlegada
                            </td>
                            <td>
                                @item.Estado
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <h4>Este Barco no tiene rutas actuales</h4>
        }
    </dl>
</div>


<div>
    @if (ViewBag.Rol == "Administrador")
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
    }
    |
    <a asp-action="Index">Back to List</a>
</div>
