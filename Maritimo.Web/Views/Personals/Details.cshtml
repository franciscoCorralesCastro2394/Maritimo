@model Maritimo.Models.Models.Personal

@{
    ViewData["Title"] = "Details";

    var hoy = DateTime.Now;
    var limite = hoy.AddDays(60);
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
        <button class="btn btn-sm btn-outline-dark"
                onclick="this.closest('.alert').remove()">
            ✖
        </button>
    </div>
}

<h1>Details</h1>

<div>
    <h4>Personal</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NombreCompleto)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NombreCompleto)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdentificacionUnica)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdentificacionUnica)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Rol)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Rol.Nombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FechaContratacion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FechaContratacion)
        </dd>
    </dl>
</div>


<br />  

<div>
    <h4> Licencias Maritimas asignadas </h4>
    <hr />
    <dl class="row">
        @if (@ViewBag.Licencias != null)
        {
            <table class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>
                           Nombre licencia
                        </th>
                        <th>
                           Estado
                        </th>
                    </tr>
                </thead>
        


            <tbody>
                    @foreach (var item in @ViewBag.Licencias)
                    {
                    <tr>
                        <td>
                            @item.NombreLicencia
                        </td>
                        
                            @if (item.FechaExpiracion <= limite)
                                {
                            <td class="bg-warning">Licencia pronto a Expirar </td>
                                } else 
                                {
                            <td class="bg-success">Licencia al día</td>
                                
                                } 
                    </tr>
                    }
            </tbody>
            </table>
        }
        else
        {
            <h4>Este Usuario no tiene Licencias asignadas</h4>
        }
    </dl>
</div>

<br />


<div>
    <h4> Barcos asignadas @Model.NombreCompleto</h4>
    <hr />
    <dl class="row">
        @if (@ViewBag.Barcos != null)
        {
            <table class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>
                            Nombre Barco
                        </th>
                        <th>
                            Matricula
                        </th>
                    </tr>
                </thead>
        


                <tbody>
                    @foreach (var item in @ViewBag.Barcos)
                    {
                        <tr>
                            <td>
                                @item.Nombre
                            </td>
                            <td>
                                @item.Matricula
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <h4>Este Personal no tiene Barcos asignados</h4>
        }
    </dl>
</div>

<br />


<div>
    <h4> Roles asignadas @Model.NombreCompleto</h4>
    <hr />
    <dl class="row">
        @if (@ViewBag.Roles != null)
        {
            <table class="table table-striped table-bordered w-100">
                <thead>
                    <tr>
                        <th>
                            Nombre Rol
                        </th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in @ViewBag.Roles)
                    {
                        <tr>
                            <td>
                                @item.Nombre
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <h4>Este Personal no tiene Barcos asignados</h4>
        }
    </dl>
</div>


<div>
    @if (ViewBag.Rol == "Administrador")
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
    }
     |
    <a asp-action="Index">Back to List</a>
</div>
