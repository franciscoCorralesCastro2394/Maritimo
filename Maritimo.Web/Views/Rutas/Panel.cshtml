@model Maritimo.Web.ViewModels.PanelVM                   


<div>
    <h4>Panel de Rutas</h4>
    <hr />
    <dl class="row">

        @if (Model.Rutas != null)
        {
            <table class="table table-striped table-bordered w-100">

                
                @using (Html.BeginForm("Panel", "Rutas", FormMethod.Get))
                {
                    <div class="row mb-3">

                        <div class="col-md-3">
                            @Html.DropDownListFor(
                            m => m.filtroBarcoId,
                            Model.Barcos,
                            "Seleccione un Barco",
                            new { @class = "form-control" })
                        </div>

                        <div class="col-md-3">
                            @Html.DropDownListFor(
                            m => m.filtroPuertoId,
                            Model.Puertos,
                            "Seleccione un puerto",
                            new { @class = "form-control" })
                        </div>

                        <div class="col-md-2">
                            <button class="btn btn-primary">
                                Buscar
                            </button>
                        </div>

                    </div>
                }



                <thead>
                    <tr>
                        <th>
                            Ruta
                        </th>
                        <th>
                            Fechas Salida
                        </th>
                        <th>
                            Fechas Llegada
                        </th>
                        <th>
                            Estado
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Rutas)
                    {
                        <tr>
                            <td>
                                @(item.puertoLlegada + " - " + item.puertoSalida)
                            </td>
                            <td>
                                @item.FechaPrevistaSalida
                            </td>
                            <td>
                                @item.FechaPrevistaLlegada
                            </td>
                            <td>
                                @item.Estado
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <h4>Este Barco no tiene rutas actuales</h4>
        }
    </dl>
</div>
<div class="mb-3">
    <a href="@Url.Action("Index", "Rutas")"
           class="btn btn-outline-primary w-100">
        Volver
    </a>
</div>